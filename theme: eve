// Check stored theme or system preference
const storedTheme =
localStorage.getItem("theme") ||
(window.matchMedia("(prefers-color-scheme: dark)").matches
? "dark"
: "light");

// Apply it immediately to <html> to avoid flash
if (storedTheme) {
document.documentElement.setAttribute(
"data-theme",
storedTheme,
);
}
</script>

