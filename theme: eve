<style type="text/css">
:root {
interpolate-size: allow-keywords;

--ff-body: "{text:Body Font}", sans-serif;
--ff-accent: "{text:Accent Font}", monospace;

--fs-body: {select:Body Font Size};
--fs-h3: calc(var(--fs-body) + 0.2rem);
--fs-h2: calc(var(--fs-body) + 0.4rem);
--fs-h1: calc(var(--fs-body) + 0.6rem);

--container-size: {select:Post Width};
--sidebar-size: {select:Sidebar Width};
--image-width: 4.5rem;

--radius-sm: 0.4rem;
--radius-round: 50%;

--ease-transition-timing: 0.8s ease-in-out;
--linear-transition-timing: 0.8s linear;
--gradient-transition-timing: --clr-gradient var(--ease-transition-timing), --clr-gradient-2 var(--ease-transition-timing);

--light-mode-filter: invert(100%);
--dark-mode-filter: invert(0);
}

:root,
html[data-theme="light"] {
--light-mode: none;
--dark-mode: flex;

--light-image: flex;
--dark-image: none;

--clr-background: {color:Light Background}; /* #f0f0f0 */
--clr-container: {color:Light Background 2}; /* #ffffff */
--clr-text: {color:Light Text}; /* #000000 */
--clr-links: {color:Light Links}; /* #505050 */
--clr-borders: hsl(from var(--clr-text) h s 40%);

--clr-accent: {color:Light Accent}; /* #BC646F */
--clr-accent-2: {color:Light Accent 2}; /* #8D4730 */

--clr-misc-accent: {color:Light Misc Accent}; /* #A7989B */
--clr-misc-accent-2: {color:Light Misc Accent 2}; /* #827671 */
}

html[data-theme="dark"] {
--light-mode: flex;
--dark-mode: none;

--light-image: none;
--dark-image: flex;

--clr-background: {color:Dark Background}; /* #202020 */
--clr-container: {color:Dark Background 2}; /* #101010 */
--clr-text: {color:Dark Text}; /* #ffffff */
--clr-links: {color:Dark Links}; /* #eeeeee */
--clr-borders: hsl(from var(--clr-text) h s 50%);

--clr-accent: {color:Dark Accent}; /* #ebb0aa  */
--clr-accent-2: {color:Dark Accent 2}; /* #dd878a */

--clr-misc-accent: {color:Dark Misc Accent}; /* #D3B8D5 */
--clr-misc-accent-2: {color:Dark Misc Accent 2}; /* #AE91B9 */
}

@property --clr-gradient {
syntax: "<color>";
initial-value: transparent;
inherits: false;
}

@property --clr-gradient-2 {
syntax: "<color>";
initial-value: transparent;
inherits: false;
}

@property --angle {
syntax: "<angle>";
initial-value: 0deg;
inherits: false;
}

*,
*::before,
*::after {
padding: 0;
margin: 0;
box-sizing: border-box;
}

html.theme-transition,
html.theme-transition * {
transition: none !important;
}

html {
font: inherit;

@media (prefers-reduced-motion: no-preference) {
scroll-behavior: smooth;
}
}

body {
background-color: var(--clr-background);
color: var(--clr-text);
font-family: var(--ff-body);
font-size: var(--fs-body);

display: grid;
grid-template-columns: 1rem [content-start] 1fr [content-end] 1rem;
}

/* global styles */
a {
color: var(--clr-links);
text-decoration: none;
transition: color var(--ease-transition-timing);

&:hover {
color: var(--clr-accent);
}
}

h1,
h2,
h3,
p,
ul:is([class], [id]),
ol:is([class], [id]) {
margin: 0;
padding: 0;
}

h1,
h2,
h3 {
font-family: var(--ff-accent);
font-weight: 600;
font-size: var(--fs-heading);
line-height: 1.2;
}

h1 {
--fs-heading: var(--fs-h1);
}

h2 {
--fs-heading: var(--fs-h2);
}

h3 {
--fs-heading: var(--fs-h3);
}

p:is(:not(:last-of-type, :only-of-type)) {
margin-block-end: 0.6rem;
}

ul:is([class], [id]),
ol:is([class], [id]) {
list-style: none;
}

i.solar-icons,
i[class^="ri-"] {
display: flex;

font-size: var(--fs-h3);
line-height: var(--fs-h3);
}

button {
background: transparent;
color: inherit;
font-family: inherit;
font-size: inherit;

border: 0;
padding: 0;
cursor: pointer;
}

s,
del {
text-decoration: 2px line-through var(--clr-accent-gradient);
opacity: 0.7;
}

/* global styles */

/* utility classes */
.icon {
display: flex;
align-items: center;
justify-content: center;

background: var(--clr-icon-bg, var(--clr-container));
background-repeat: no-repeat;
color: var(--clr-icon, inherit);
padding: 0.4rem;
border: 1px solid var(--clr-icon-borders, var(--clr-borders));
border-radius: var(--icon-radius, var(--radius-sm));
}

.fit-cover {
object-fit: cover;
}

.grid-stack,
.stack {
display: grid;
justify-items: start;
gap: var(--grid-gap, 10px);
z-index: 1;
}

.light-mode {
display: var(--light-mode);
}

.dark-mode {
display: var(--dark-mode);
}

.light-image {
display: var(--light-image);
}

.dark-image {
display: var(--dark-image);
}

.inner-text,
.text-inner {
margin-block-start: var(--margin-block-start, 0);
margin-block-end: var(--margin-block-end, 0);
}

.icon-wrapper {
width: var(--image-width);
aspect-ratio: 1;
padding: 0.4rem;
border-radius: var(--image-radius, var(--radius-round));

&.linear-gradient {
background: linear-gradient(to bottom, var(--clr-container)) padding-box, linear-gradient(to bottom, var(--clr-borders), var(--clr-icon-accent)) border-box;
border: 1px solid transparent;
}

&.conic-gradient {
background: linear-gradient(to bottom, var(--clr-container)) padding-box, conic-gradient(from var(--angle), var(--clr-borders) 80%, var(--clr-icon-accent) 0) border-box;
border: 1px solid transparent;
}
}

.icon-wrapper,
.image-wrapper {
img {
width: 100%;
height: 100%;

display: block;
border-radius: inherit;
}
}

.text-list:not(:has(.project-text)) {
display: block;

li {
display: inline;

p {
display: inline;
}

&:not(:last-of-type)::after {
content: ',';
margin-inline: 0px 5px;
}
}
}

ul.flex {
display: flex;
gap: 10px;

html.lines-divider & li:not(:has(i, .dot)) {
display: flex;
gap: 10px;

&:not(:last-of-type)::after {
content: "";
width: 1px;
background: var(--clr-borders);
flex-shrink: 0;
}
}

html.dots-divider & li:not(:has(i, .dot)) {
display: flex;
align-items: center;
gap: 10px;

&:not(:last-of-type)::after {
content: "";
width: 6px;
aspect-ratio: 1;
background: var(--clr-accent);
border-radius: var(--radius-round);
}
}
}

ul.inline-block {
display: block;

li {
display: inline;

&::after {
content: '';
display: inline-block;

vertical-align: middle;
margin-inline: 5px;
}
}

html.lines-divider & li:not(:has(i, .dot)) {
&:not(:last-of-type)::after {
width: 1px;
height: 2ch;
background: var(--clr-borders);
}
}

html.dots-divider & li:not(:has(i, .dot)) {
&:not(:last-of-type)::after {
width: 6px;
aspect-ratio: 1;
background: var(--clr-accent);
border-radius: var(--radius-round);
}
}
}
/* utility classes */

/* modal styles */
.modal {
position: fixed;
background: hsl(from var(--clr-background) h s l / 0.7);
z-index: 1000;
width: 100%;
height: 100%;
inset: 0;

overflow: auto;
overscroll-behavior: contain;
cursor: pointer;

transition: opacity var(--linear-transition-timing), visibility var(--linear-transition-timing);

@media (prefers-reduced-motion: no-preference) {
& .modal-container {
transform: translateY(-5rem);
transition: var(--linear-transition-timing);
}
}
}

.modal.hide {
opacity: 0;
visibility: hidden;
}

.modal:not(.hide) {
opacity: 1;
visibility: visible;

@media (prefers-reduced-motion: no-preference) {
& .modal-container {
transform: translateY(0rem);
transition: var(--linear-transition-timing);
}
}
}

.modal-dialog {
position: relative;
}

.close-modal-wrapper {
position: absolute;
top: 0;
right: 0;
translate: -1rem -3rem;
}

.close-modal-btn {
--clr-gradient: var(--clr-accent);
--clr-gradient-2: var(--clr-accent-2);

--clr-icon-bg: linear-gradient(to bottom, var(--clr-gradient), var(--clr-gradient-2));

transition: var(--gradient-transition-timing);

&:hover {
--clr-gradient: var(--clr-container);
--clr-gradient-2: var(--clr-container);
}

i {
--clr-gradient: var(--clr-background);
--clr-gradient-2: var(--clr-background);

background: linear-gradient(to bottom, var(--clr-gradient), var(--clr-gradient));
background-clip: text;
color: transparent;
transition: var(--gradient-transition-timing);
}

&:hover i {
--clr-gradient: var(--clr-misc-accent);
--clr-gradient-2: var(--clr-misc-accent-2);
}
}

.modal-container {
margin: 4rem auto;

width: 100%;
max-width: var(--container-size);

@media screen and (width >= 900px) {
width: var(--container-size);
}
}

.faves-wrapper {
&:not(:last-child)::after {
content: '';
width: 50%;
height: 1px;
background: var(--clr-borders);

display: block;
margin-block: 1.2rem;
margin-inline: auto;
}

&:nth-of-type(odd) {
.faves-icon i {
--clr-gradient: var(--clr-misc-accent);
--clr-gradient-2: var(--clr-misc-accent-2);
}
}

&:nth-of-type(even) {
.faves-icon i {
--clr-gradient: var(--clr-accent);
--clr-gradient-2: var(--clr-accent-2);
}
}
}

.faves-title {
display: flex;
align-items: center;
justify-content: space-between;
gap: 10px;

border-bottom: 1px solid var(--clr-borders);
padding-block-end: 0.5rem;
margin-block-end: 0.5rem;

b {
font-size: calc(var(--fs-body) + 0.1rem);
font-family: var(--ff-accent);
}
}

.faves-icon {
i {
background: linear-gradient(to bottom, var(--clr-gradient), var(--clr-gradient-2));
background-clip: text;
color: transparent;
}
}
/* modal styles */

/* main grid styles */
.main-grid {
--nav-sidebar-size: 3rem;

grid-area: content;
display: grid;
grid-template-columns: var(--nav-sidebar-size) auto;
align-items: start;
grid-auto-flow: dense;
gap: 3rem;

min-height: 100vh;
min-height: 100dvh;
}
/* main grid styles */

/* nav sidebar styles */
.nav-sidebar {
width: var(--nav-sidebar-size);

grid-column: 1;
align-self: stretch;
margin-inline-start: 1rem;
}

.tabs-list {
height: 100%;

display: grid;
gap: 3rem;
border-left: 1px solid var(--clr-borders);

align-content: center;

position: fixed;

li {
position: relative;

button {
background: var(--clr-background);
padding: 0.4rem;
border-radius: var(--radius-round);

position: absolute;
top: 0;
left: 0;
transform: translateX(-50%);
}
}
}

.tab {
button[aria-selected="true"] {
background: var(--clr-text);
color: var(--clr-background);
}
}
/* nav sidebar styles */

/* main wrapper styles */
.main-wrapper {
grid-column: 2;

display: grid;
justify-content: start;
gap: 3rem;

margin: 4rem auto;
}
/* main wrapper styles */

/* panel wrapper styles */
.panels-group {
& > * {
animation: fade-in var(--linear-transition-timing);
}
}

.panel-wrapper:not(.posts-panel, .about-panel, .projects-panel) {
max-width: var(--container-size);
width: 100%;

@media screen and (width >= 900px) {
